+#
+
+DEVICE_PATH := device/zte/sm88XX
+
+# Candidate D1T: D1 no-decrypt base plus touch/input lockscreen isolation.
+$(call inherit-product, $(DEVICE_PATH)/orangefox_NX809J_codingbr_d1.mk)
+
+PRODUCT_NAME := orangefox_NX809J_codingbr_d1t
+PRODUCT_DEVICE := sm88XX
+PRODUCT_BRAND := REDMAGIC
+PRODUCT_MANUFACTURER := nubia
+PRODUCT_MODEL := REDMAGIC 11 Pro
+PRODUCT_SYSTEM_DEVICE := NX809J
+PRODUCT_SYSTEM_NAME := NX809J-UN
+PRODUCT_SYSTEM_BRAND := REDMAGIC
+PRODUCT_SYSTEM_MANUFACTURER := nubia
+PRODUCT_SYSTEM_MODEL := REDMAGIC 11 Pro
+
+PRODUCT_PRODUCT_PROPERTIES += \
+    ro.rm11.touch_candidate=d1t-touch-input-isolation
--- /dev/null	2026-06-10 23:17:44.149793421 -0500
+++ device/zte/sm88XX/d1t/recovery/root/system/bin/unbind_inputs.sh	2026-06-11 00:02:49.116778424 -0500
@@ -0,0 +1,37 @@
+#!/system/bin/sh
+
+# Keep the Synaptics touch controller alive and remove only known non-touch
+# sources that can pollute recovery's input device scan.
+sleep 2
+
+deleted=0
+
+for dev in /sys/class/input/input*; do
+    [ -e "$dev/name" ] || continue
+
+    name=$(cat "$dev/name")
+    case "$name" in
+        hbtp_vm|goodix_fp|nubia_tgk_aw_sar0_ch0|nubia_tgk_aw_sar1_ch0)
+            ;;
+        *)
+            continue
+            ;;
+    esac
+
+    dev_path=$(readlink -f "$dev/device")
+    if [ -n "$dev_path" ] && [ -e "$dev_path/driver/unbind" ]; then
+        dev_name=${dev_path##*/}
+        echo "$dev_name" > "$dev_path/driver/unbind"
+        deleted=1
+    fi
+
+    event_name=$(find "$dev" -maxdepth 1 -name 'event*' -printf '%f\n' | head -n 1)
+    if [ -n "$event_name" ] && [ -e "/dev/input/$event_name" ]; then
+        rm -f "/dev/input/$event_name"
+        deleted=1
+    fi
+done
+
+if [ "$deleted" -eq 1 ]; then
+    killall recovery
+fi
