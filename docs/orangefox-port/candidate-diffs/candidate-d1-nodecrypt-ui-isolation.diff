@@ -0,0 +1,20 @@
+# Candidate D1: vendor health service is disabled to avoid Android 16 vendor
+# linker/runtime restart loops while proving the recovery UI path.
+
+service vendor.health-default /vendor/bin/hw/android.hardware.health-service.qti
+    class hal
+    user system
+    group system
+    capabilities WAKE_ALARM BLOCK_SUSPEND
+    file /dev/kmsg w
+    disabled
+    seclabel u:r:recovery:s0
+
+service vendor.charger /vendor/bin/hw/android.hardware.health-service.qti --charger
+    class charger
+    user system
+    group system wakelock input graphics
+    capabilities SYS_BOOT WAKE_ALARM BLOCK_SUSPEND
+    file /dev/kmsg w
+    disabled
+    seclabel u:r:charger_vendor:s0
