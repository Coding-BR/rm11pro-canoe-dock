--- /dev/null	2026-06-10 23:17:44.149793421 -0500
+++ device/zte/sm88XX/orangefox_NX809J_codingbr_d1.mk	2026-06-10 23:23:12.009646655 -0500
@@ -0,0 +1,27 @@
+#
+# Copyright (C) 2026 The OrangeFox Recovery Project
+# SPDX-License-Identifier: GPL-3.0-or-later
+#
+
+DEVICE_PATH := device/zte/sm88XX
+
+# Candidate D1: no-decrypt UI isolation.
+#
+# This product keeps the bootable Coding-BR sm88XX/NX809J lane intact and adds a
+# separate lunch target that suppresses the Android 16 decrypt/security runtime
+# while testing whether OrangeFox can advance past splash into full UI.
+$(call inherit-product, $(DEVICE_PATH)/orangefox_NX809J_codingbr.mk)
+
+PRODUCT_NAME := orangefox_NX809J_codingbr_d1
+PRODUCT_DEVICE := sm88XX
+PRODUCT_BRAND := REDMAGIC
+PRODUCT_MANUFACTURER := nubia
+PRODUCT_MODEL := REDMAGIC 11 Pro
+PRODUCT_SYSTEM_DEVICE := NX809J
+PRODUCT_SYSTEM_NAME := NX809J-UN
+PRODUCT_SYSTEM_BRAND := REDMAGIC
+PRODUCT_SYSTEM_MANUFACTURER := nubia
+PRODUCT_SYSTEM_MODEL := REDMAGIC 11 Pro
+
+PRODUCT_PRODUCT_PROPERTIES += \
+    ro.rm11.candidate=d1-nodecrypt-ui-isolation
--- /dev/null	2026-06-10 23:17:44.149793421 -0500
+++ device/zte/sm88XX/d1/recovery/root/init.recovery.qcom.rc	2026-06-10 23:23:12.029646649 -0500
@@ -0,0 +1,56 @@
+# Copyright (c) 2017-2018,2020-2021 The Linux Foundation. All rights reserved.
+#
+# Candidate D1 overlay for NX809J: keep display/touch/module bring-up, but do
+# not start the Android 16 decrypt/security service stack during UI isolation.
+
+on init
+    write /sys/fs/selinux/checkreqprot 0
+
+service post-boot-script /system/bin/sh -c /vendor/bin/init.kernel.post_boot-canoe_default_6_2.sh
+    user root
+    group root
+    oneshot
+    seclabel u:r:recovery:s0
+
+service unbind_inputs /system/bin/sh /system/bin/unbind_inputs.sh
+    user root
+    group root
+    oneshot
+    seclabel u:r:recovery:s0
+
+on init
+    write /sys/class/backlight/panel0-backlight/brightness 200
+    setprop sys.usb.configfs 1
+
+on property:ro.boot.usbcontroller=*
+    setprop sys.usb.controller ${ro.boot.usbcontroller}
+    wait /sys/bus/platform/devices/${ro.boot.usb.dwc3_msm:-a600000.ssusb}/mode
+    write /sys/bus/platform/devices/${ro.boot.usb.dwc3_msm:-a600000.ssusb}/mode peripheral
+    wait /sys/class/udc/${ro.boot.usbcontroller} 1
+
+on fs
+    wait /dev/block/platform/soc/${ro.boot.bootdevice}
+    symlink /dev/block/platform/soc/${ro.boot.bootdevice} /dev/block/bootdevice
+    write /proc/sys/kernel/firmware_config/force_sysfs_fallback 1
+
+on property:twrp.modules.loaded=true
+    mkdir /firmware
+    mount vfat /dev/block/bootdevice/by-name/modem${ro.boot.slot_suffix} /firmware ro
+    wait /sys/kernel/boot_adsp/ssr
+    write /sys/kernel/boot_adsp/ssr 1
+    wait /sys/class/power_supply/battery
+    start unbind_inputs
+
+on property:hwservicemanager.ready=true
+    setprop sys.boot_completed 1
+
+# Touch drivers
+chmod 0644 /firmware/syna_firmware.img
+
+on boot
+    chown root root /lib/firmware
+    chmod 0755 /lib/firmware
+
+    chmod 0644 /lib/firmware/syna_firmware.img
+    chmod 0644 /lib/firmware/haptic_ram.bin
+    chmod 0644 /lib/firmware/awinic_haptic_params.bin
--- /dev/null	2026-06-10 23:17:44.149793421 -0500
